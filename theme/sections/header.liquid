<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">

      <div class="header-left">
        <button class="mobile-menu-btn" aria-label="Open menu" aria-controls="mobile-nav" aria-expanded="false">
          <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>

        <a href="{{ routes.root_url }}" class="site-logo" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name, loading: 'eager' }}
          {%- else -%}
            {{ shop.name | upcase }}
          {%- endif -%}
        </a>

        <nav class="header-nav" aria-label="Main navigation">
          {%- for link in linklists[section.settings.menu].links -%}
            <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          {%- endfor -%}
        </nav>
      </div>

      <div class="header-right">
        <button class="header-icon-btn" aria-label="Search">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>

        <a href="{{ routes.account_url }}" class="header-icon-btn account-btn" aria-label="Account">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>

        <a href="{{ routes.cart_url }}" class="header-icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          {%- if cart.item_count > 0 -%}
            <span class="cart-badge" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>
      </div>

    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
