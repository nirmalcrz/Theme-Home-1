<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand column -->
      <div>
        <a href="{{ routes.root_url }}" class="footer-brand-logo">{{ shop.name | upcase }}</a>
        <p class="footer-brand-desc">{{ section.settings.brand_description }}</p>
        <div class="footer-socials">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.twitter_url != blank -%}
            <a href="{{ section.settings.twitter_url }}" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X">
              <svg viewBox="0 0 24 24"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.youtube_url != blank -%}
            <a href="{{ section.settings.youtube_url }}" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Shop links -->
      <div>
        <h4 class="footer-col-heading">Shop</h4>
        <ul class="footer-nav">
          {%- for link in linklists[section.settings.shop_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="{{ routes.all_products_collection_url }}">All Products</a></li>
            <li><a href="#">New Arrivals</a></li>
            <li><a href="#">Bestsellers</a></li>
            <li><a href="{{ routes.collections_url }}">Collections</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Support links -->
      <div>
        <h4 class="footer-col-heading">Support</h4>
        <ul class="footer-nav">
          {%- for link in linklists[section.settings.support_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- else -%}
            <li><a href="#">Shipping Policy</a></li>
            <li><a href="#">Returns & Exchanges</a></li>
            <li><a href="#">Help Center</a></li>
            <li><a href="#">Contact Us</a></li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h4 class="footer-col-heading">Newsletter</h4>
        <p class="footer-newsletter-desc">{{ section.settings.newsletter_text }}</p>
        {%- form 'customer', id: 'footer-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer-newsletter-form">
            <input
              type="email"
              name="contact[email]"
              class="footer-newsletter-input"
              placeholder="Enter your email"
              autocomplete="email"
              required
              aria-label="Email address"
            >
            <button type="submit" class="footer-newsletter-btn">Join</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p style="color: var(--color-accent); font-size: 13px; margin-top: 8px; font-weight: 600;">Thanks for subscribing!</p>
          {%- endif -%}
        {%- endform -%}
      </div>

    </div>

    <div class="footer-bottom">
      {%- assign current_year = 'now' | date: '%Y' -%}
      <p>{{ section.settings.copyright | replace: '[year]', current_year }}</p>
      <div class="footer-legal-links">
        {%- if shop.privacy_policy != blank -%}
          <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
        {%- endif -%}
        {%- if shop.terms_of_service != blank -%}
          <a href="{{ shop.terms_of_service.url }}">Terms of Service</a>
        {%- endif -%}
      </div>
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Elevating daily rituals through premium essentials and sustainable craftsmanship."
    },
    {
      "type": "link_list",
      "id": "shop_menu",
      "label": "Shop menu"
    },
    {
      "type": "link_list",
      "id": "support_menu",
      "label": "Support menu"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Join our community for early access and exclusive offers."
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© [year] Lumina Essentials. All rights reserved."
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "twitter_url",
      "label": "Twitter / X URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    }
  ]
}
{% endschema %}
