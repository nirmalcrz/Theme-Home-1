<section class="trust-section">
  <div class="container">
    <div class="trust-grid">
      {%- for block in section.blocks -%}
        <div class="trust-item" {{ block.shopify_attributes }}>
          <div class="trust-icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'refresh' -%}
                <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'headphones' -%}
                <svg viewBox="0 0 24 24"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
            {%- endcase -%}
          </div>
          <div>
            <p class="trust-item-title">{{ block.settings.title }}</p>
            <p class="trust-item-desc">{{ block.settings.description }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck / Shipping" },
            { "value": "refresh", "label": "Refresh / Returns" },
            { "value": "shield", "label": "Shield / Security" },
            { "value": "headphones", "label": "Headphones / Support" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On all orders over $100"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck", "title": "Free Shipping", "description": "On all orders over $100" } },
        { "type": "trust_item", "settings": { "icon": "refresh", "title": "Easy Returns", "description": "60-day money back guarantee" } },
        { "type": "trust_item", "settings": { "icon": "shield", "title": "Secure Payment", "description": "100% protected checkout" } },
        { "type": "trust_item", "settings": { "icon": "headphones", "title": "24/7 Support", "description": "Dedicated expert assistance" } }
      ]
    }
  ]
}
{% endschema %}
